# Google Actions Center Configuration

# Business Information
VITE_BUSINESS_ID=your-business-uuid
VITE_BUSINESS_NAME=Your Business Name
VITE_CHECKOUT_BASE_URL=https://yourpos.com

# POS System Integration
VITE_POS_WEBHOOK_URL=https://yourpos.com/webhook/google-order
VITE_POS_WEBSOCKET_URL=ws://localhost:3001
VITE_WEBHOOK_SECRET=your-webhook-secret-key-min-32-chars

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Cloud Configuration (Optional)
GOOGLE_PROJECT_ID=your-google-project-id
GOOGLE_MERCHANT_ID=your-google-merchant-id

# Email Configuration
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=orders@yourpos.com

# Application URLs
VITE_APP_URL=https://yourpos.com
VITE_API_URL=https://yourpos.com/api

# Feature Flags
VITE_ENABLE_GOOGLE_ACTIONS=true
VITE_ENABLE_WEBSOCKET_NOTIFICATIONS=true
VITE_ENABLE_PAYMENT_WEBHOOK=true

# Logging
VITE_LOG_LEVEL=info
SUPABASE_LOG_LEVEL=info

# Performance
VITE_CACHE_MENU_FEED_MINUTES=60
VITE_ORDER_POLLING_INTERVAL=5000
VITE_WEBSOCKET_RECONNECT_DELAY=3000
